{
  "name": "Maintenance System MIS Codespace",
  "image": "mcr.microsoft.com/devcontainers/php:8.2",
  "features": {
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "forwardPorts": [8000],
  "portsAttributes": {
    "8000": {
      "label": "Laravel Server",
      "onAutoForward": "openPreview"
    }
  },
  "postCreateCommand": "cp -n .env.example .env || true && composer install && npm install && npm run build && php artisan key:generate --ansi",
  "customizations": {
    "vscode": {
      "extensions": [
        "bmewburn.vscode-intelephense-client",
        "onecentlin.laravel-blade",
        "amiralvarez.laravel-discover"
      ]
    }
  }
}
